{
  "ConnectionStrings": {
    "AdeniDb": "Host=localhost;Port=5432;Database=adeni;Username=adeni;Password=adeni_dev_password"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Auth0": {
    "Enabled": false,
    "Domain": "your-tenant.auth0.com",
    "Audience": "https://api.adeni.io",
    "RequireMfaForAdmin": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Observability": {
    "Enabled": false,
    "ServiceName": "adeni-api"
  },
  "Market": {
    "DefaultTimeZoneId": "Africa/Lagos"
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "RootPath": "./.data/media",
      "PublicBaseUrl": "http://localhost:5169/media",
      "ApiBaseUrl": "http://localhost:5169",
      "UploadSigningKey": "dev-upload-signing-key"
    },
    "AzureBlob": {
      "ConnectionString": "",
      "PublicContainer": "media",
      "PublicBaseUrl": ""
    }
  },
  "Translation": {
    "Endpoint": "https://api.cognitive.microsofttranslator.com",
    "Key": "",
    "Region": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
