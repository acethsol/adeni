{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "Enabled": false,
    "ServiceName": "adeni-api"
  },
  "Market": {
    "DefaultTimeZoneId": "UTC"
  },
  "AllowedHosts": "*"
}
