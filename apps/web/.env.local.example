# Auth0 + API (local development)
APP_BASE_URL=http://localhost:3000
ADENI_API_URL=http://localhost:5169
NEXT_PUBLIC_ADENI_API_URL=http://localhost:5169
# Optional dev fallback when location is unavailable (geo overrides this when granted)
# NEXT_PUBLIC_ADENI_MARKET=lagos

AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_AUDIENCE=https://api.adeni.io

# Generate AUTH0_SECRET (PowerShell):
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))

# Auth0 Dashboard → Application → Settings:
# - Callback URLs: http://localhost:3000/auth/callback
# - Logout URLs: http://localhost:3000
# - Web Origins: http://localhost:3000

# Enable JWT validation on the API when testing end-to-end:
# src/Adeni.Api/appsettings.Development.json → "Auth0": { "Enabled": true }

# Local booking without Auth0 (maps to X-Dev-Auth0-Sub on the API):
DEV_CUSTOMER_AUTH0_SUB=auth0|local-customer

# Azure Translator (production). Dev falls back to MyMemory when unset.
# Set on the API (Adeni.Api), not the web app:
# Translation__Key=
# Translation__Region=canadacentral
# Translation__Endpoint=https://api.cognitive.microsofttranslator.com

# Local business portal (linked to lekki-cuts in dev seed):
DEV_BUSINESS_AUTH0_SUB=auth0|local-business
