# Physical device: use your machine's LAN IP (not localhost)
# EXPO_PUBLIC_ADENI_API_URL=http://192.168.1.10:5169

# Auth0 Native (optional — omit for local dev with subs below)
# EXPO_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
# EXPO_PUBLIC_AUTH0_CLIENT_ID=
# EXPO_PUBLIC_AUTH0_AUDIENCE=https://api.adeni.io
# Auth0 Dashboard → Native app → Callback URLs: adeni://callback

# Local booking without Auth0 (maps to X-Dev-Auth0-Sub on the API)
EXPO_PUBLIC_DEV_CUSTOMER_AUTH0_SUB=auth0|local-customer

# Local business inbox (linked to lekki-cuts in dev seed)
EXPO_PUBLIC_DEV_BUSINESS_AUTH0_SUB=auth0|local-business

# Optional fallback when location is unavailable
# EXPO_PUBLIC_ADENI_MARKET=lagos
