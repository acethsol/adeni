{
  "name": "adeni",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @adeni/web",
    "dev:mobile": "npm run start --workspace @adeni/mobile",
    "build:web": "npm run build --workspace @adeni/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
